{
  "version": "1.0",
  "ai": {
    "provider": "gemini",
    "model": "gemini-2.0-flash",
    "api_key_env": "GEMINI_API_KEY",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 2,
    "analysis_concurrency": 1,
    "enrichment_concurrency": 1
  },
  "email": {
    "enabled": false,
    "smtp_server": "smtp-mail.outlook.com",
    "smtp_port": 587,
    "imap_enabled": false,
    "imap_server": "outlook.office365.com",
    "imap_port": 993,
    "email_address": "adil.hasanov@hotmail.com",
    "sender_name": "Horizon Daily",
    "subscribe_keyword": "SUBSCRIBE",
    "unsubscribe_keyword": "UNSUBSCRIBE"
  },
  "sources": {
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 100
    },
    "reddit": {
      "enabled": true,
      "fetch_comments": 3,
      "subreddits": [
        {
          "subreddit": "devops",
          "sort": "hot",
          "fetch_limit": 15,
          "min_score": 50
        },
        {
          "subreddit": "kubernetes",
          "sort": "hot",
          "fetch_limit": 15,
          "min_score": 30
        },
        {
          "subreddit": "Terraform",
          "sort": "hot",
          "fetch_limit": 10,
          "min_score": 20
        },
        {
          "subreddit": "selfhosted",
          "sort": "hot",
          "fetch_limit": 10,
          "min_score": 50
        },
        {
          "subreddit": "netsec",
          "sort": "hot",
          "fetch_limit": 10,
          "min_score": 50
        }
      ],
      "users": []
    },
    "rss": [
      {
        "name": "The New Stack",
        "url": "https://thenewstack.io/feed/",
        "enabled": true,
        "category": "devops"
      },
      {
        "name": "CNCF Blog",
        "url": "https://www.cncf.io/feed/",
        "enabled": true,
        "category": "cloud-native"
      },
      {
        "name": "Kubernetes Blog",
        "url": "https://kubernetes.io/feed.xml",
        "enabled": true,
        "category": "kubernetes"
      },
      {
        "name": "GitHub Engineering",
        "url": "https://github.blog/engineering.atom",
        "enabled": true,
        "category": "engineering"
      },
      {
        "name": "Docker Blog",
        "url": "https://www.docker.com/blog/feed/",
        "enabled": true,
        "category": "containers"
      },
      {
        "name": "Cloudflare Blog",
        "url": "https://blog.cloudflare.com/rss/",
        "enabled": true,
        "category": "networking"
      },
      {
        "name": "GitLab Blog",
        "url": "https://about.gitlab.com/atom.xml",
        "enabled": true,
        "category": "devops"
      }
    ],
    "github": [
      {
        "type": "repo_releases",
        "owner": "kubernetes",
        "repo": "kubernetes",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "hashicorp",
        "repo": "terraform",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "opentofu",
        "repo": "opentofu",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "argoproj",
        "repo": "argo-cd",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "grafana",
        "repo": "grafana",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "prometheus",
        "repo": "prometheus",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "helm",
        "repo": "helm",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "cilium",
        "repo": "cilium",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "cloudflare",
        "repo": "cloudflared",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "cloudflare",
        "repo": "workers-sdk",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "gitlab-org",
        "repo": "gitlab",
        "enabled": true
      }
    ],
    "ossinsight": {
      "enabled": true,
      "period": "past_24_hours",
      "languages": [
        "Go",
        "Python",
        "Rust",
        "Shell"
      ],
      "keywords": [
        "kubernetes",
        "docker",
        "terraform",
        "observability",
        "platform",
        "devops",
        "infra",
        "cloud"
      ],
      "min_stars": 20,
      "max_items": 20
    }
  },
  "filtering": {
    "ai_score_threshold": 0.0,
    "time_window_hours": 24
  },
  "webhook": {
    "enabled": true,
    "url_env": "TELEGRAM_WEBHOOK_URL",
    "delivery": "summary_and_items",
    "overview_position": "last",
    "platform": "generic",
    "layout": "markdown",
    "request_body": {
      "chat_id": "${TELEGRAM_CHAT_ID}",
      "text": "#{summary}",
      "parse_mode": "Markdown"
    }
  }
}